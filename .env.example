# 复制为 .env 后修改：cp .env.example .env

# 必改：JWT 密钥（可用 openssl rand -hex 32 生成）
FLOWAGENT_JWT_SECRET=change-me-in-production

# 短信：dev=固定验证码不发真短信；生产接阿里云改为 aliyun
FLOWAGENT_SMS_PROVIDER=dev
FLOWAGENT_SMS_DEV_CODE=123456

# 阿里云短信（FLOWAGENT_SMS_PROVIDER=aliyun 时填写）
# FLOWAGENT_SMS_ACCESS_KEY_ID=
# FLOWAGENT_SMS_ACCESS_KEY_SECRET=
# FLOWAGENT_SMS_SIGN_NAME=
# FLOWAGENT_SMS_TEMPLATE_CODE=

# 对外端口（默认 8080）
FLOWAGENT_PORT=8080
